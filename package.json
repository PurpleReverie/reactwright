{
  "name": "reactdoc",
  "version": "0.0.0",
  "private": true,
  "description": "React-authored document engine prototype",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./jsx": {
      "types": "./src/public/jsx.d.ts",
      "default": "./src/public/jsx.js"
    },
    "./contract": {
      "types": "./src/public/contract.ts",
      "default": "./src/public/contract.ts"
    }
  },
  "scripts": {
    "dev": "node --import tsx -e \"import('reactdoc').then(() => console.log('reactdoc package entry loaded'))\"",
    "check": "tsc --noEmit",
    "check:intellisense": "tsc -p fixtures/intellisense-consumer/tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/**/*.test.tsx",
    "run:file": "node --import tsx ./src/cli/run-file.tsx",
    "mockup:treatise": "node --import tsx ./src/cli/run-file.tsx ./mockups/treatise.tsx --format html --out ./build/mockups",
    "mockup:field-notes": "node --import tsx ./src/cli/run-file.tsx ./mockups/field-notes.tsx --format html --out ./build/mockups",
    "mockup:chapter-three": "node --import tsx ./src/cli/run-file.tsx ./mockups/chapter-three.tsx --format html --out ./build/mockups",
    "mockup:newsletter": "node --import tsx ./src/cli/run-file.tsx ./mockups/newsletter.tsx --format html --out ./build/mockups",
    "mockup:cover": "node --import tsx ./src/cli/run-file.tsx ./mockups/cover.tsx --format html --out ./build/mockups",
    "example:minimal": "node --import tsx ./src/examples/minimal.tsx",
    "example:template": "node --import tsx ./src/examples/template.tsx",
    "example:resolve": "node --import tsx ./src/examples/resolve.tsx",
    "example:html": "node --import tsx ./src/examples/html.tsx"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-reconciler": "^0.31.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
