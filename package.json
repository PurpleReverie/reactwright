{
  "name": "reactdoc",
  "version": "0.0.0",
  "private": true,
  "description": "React-authored document engine prototype",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./jsx": {
      "types": "./src/public/jsx.d.ts",
      "default": "./src/public/jsx.js"
    },
    "./contract": {
      "types": "./src/public/contract.ts",
      "default": "./src/public/contract.ts"
    }
  },
  "scripts": {
    "dev": "node --import tsx -e \"import('reactdoc').then(() => console.log('reactdoc package entry loaded'))\"",
    "check": "tsc --noEmit",
    "check:intellisense": "tsc -p fixtures/intellisense-consumer/tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/**/*.test.tsx",
    "run:file": "PUPPETEER_EXECUTABLE_PATH=\"${PUPPETEER_EXECUTABLE_PATH:-/Applications/Google Chrome.app/Contents/MacOS/Google Chrome}\" node --import tsx ./src/cli/run-file.tsx",
    "mockup:treatise": "npm run -s run:file -- ./mockups/treatise.tsx --format html,pdf --out ./build/mockups",
    "mockup:field-notes": "npm run -s run:file -- ./mockups/field-notes.tsx --format html,pdf --out ./build/mockups",
    "mockup:chapter-three": "npm run -s run:file -- ./mockups/chapter-three.tsx --format html,pdf --out ./build/mockups",
    "mockup:newsletter": "npm run -s run:file -- ./mockups/newsletter.tsx --format html,pdf --out ./build/mockups",
    "mockup:cover": "npm run -s run:file -- ./mockups/cover.tsx --format html,pdf --out ./build/mockups",
    "mockup:ieee": "npm run -s run:file -- ./mockups/ieee.tsx --format html,pdf --out ./build/mockups",
    "mockup:long-form": "npm run -s run:file -- ./mockups/long-form.tsx --format html,pdf --out ./build/mockups",
    "mockup:ieee-long": "npm run -s run:file -- ./mockups/ieee-long.tsx --format html,pdf --out ./build/mockups",
    "mockup:story-bible": "npm run -s run:file -- ./mockups/story-bible.tsx --format html,pdf --out ./build/mockups",
    "mockup:ieee-strict": "npm run -s run:file -- ./mockups/ieee-strict.tsx --format html,pdf --out ./build/mockups",
    "mockup:all": "npm run -s mockup:treatise && npm run -s mockup:field-notes && npm run -s mockup:chapter-three && npm run -s mockup:newsletter && npm run -s mockup:cover && npm run -s mockup:ieee && npm run -s mockup:ieee-long && npm run -s mockup:long-form && npm run -s mockup:story-bible && npm run -s mockup:ieee-strict",
    "snapshot:treatise": "npm run -s run:file -- ./mockups/treatise.tsx --format png --out ./build/snapshots",
    "snapshot:field-notes": "npm run -s run:file -- ./mockups/field-notes.tsx --format png --out ./build/snapshots",
    "snapshot:chapter-three": "npm run -s run:file -- ./mockups/chapter-three.tsx --format png --out ./build/snapshots",
    "snapshot:newsletter": "npm run -s run:file -- ./mockups/newsletter.tsx --format png --out ./build/snapshots",
    "snapshot:cover": "npm run -s run:file -- ./mockups/cover.tsx --format png --out ./build/snapshots",
    "snapshot:ieee": "npm run -s run:file -- ./mockups/ieee.tsx --format png --out ./build/snapshots",
    "snapshot:ieee-long": "npm run -s run:file -- ./mockups/ieee-long.tsx --format png --out ./build/snapshots",
    "snapshot:long-form": "npm run -s run:file -- ./mockups/long-form.tsx --format png --out ./build/snapshots",
    "snapshot:story-bible": "npm run -s run:file -- ./mockups/story-bible.tsx --format png --out ./build/snapshots",
    "snapshot:ieee-strict": "npm run -s run:file -- ./mockups/ieee-strict.tsx --format png --out ./build/snapshots",
    "snapshot:all": "npm run -s snapshot:treatise && npm run -s snapshot:field-notes && npm run -s snapshot:chapter-three && npm run -s snapshot:newsletter && npm run -s snapshot:cover && npm run -s snapshot:ieee && npm run -s snapshot:ieee-long && npm run -s snapshot:long-form && npm run -s snapshot:story-bible && npm run -s snapshot:ieee-strict"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-reconciler": "^0.31.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "katex": "^0.17.0",
    "puppeteer-core": "^25.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
