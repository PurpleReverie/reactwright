{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "reactdoc": ["../../src/index.ts"],
      "reactdoc/jsx": ["../../src/public/jsx.d.ts"],
      "reactdoc/templates": ["../../src/public/templates.ts"]
    },
    "types": ["node", "react"]
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../../src/types/**/*.d.ts"]
}
